{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.1-free",
  "plugin": ["@different-ai/opencode-browser"],
  "tools": {
    "browser_*": false,
    "google-workspace-official_*": false
  },
  "mcp": {
    "fireflies": {
      "type": "remote",
      "url": "https://api.fireflies.ai/mcp",
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": false
    },
    "google-workspace-official": {
      "type": "local",
      "enabled": false,
      "timeout": 120000,
      "command": [
        "bash",
        "-lc",
        "source \"$HOME/.nvm/nvm.sh\" && nvm use 22 >/dev/null && exec npx -y github:gemini-cli-extensions/workspace gemini-workspace-server"
      ]
    },
    "clickup": {
      "type": "remote",
      "url": "https://mcp.clickup.com/mcp",
      "enabled": false
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "browser_*": false
      }
    },
    "plan": {
      "mode": "primary",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "browser_*": false
      }
    },
    "learn": {
      "description": "Helps explore questions, generate solutions, and understand concepts",
      "mode": "primary",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "browser_*": false
      }
    },
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "browser_*": false
      }
    },
    "fireflies": {
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "fireflies": true,
        "playwright": false,
        "figma": false
      }
    },
    "playwright": {
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "fireflies": false,
        "playwright": true,
        "figma": false
      }
    },
    "figma": {
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "fireflies": false,
        "playwright": false,
        "figma": true
      }
    },
    "google-docs": {
      "description": "Google Docs focused workspace subagent",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "google-workspace-official_docs_*": true,
        "google-workspace-official_auth_*": true,
        "google-workspace-official_time_*": true,
        "google-workspace-official_people_*": true,
        "google-workspace-official_chat_*": false
      }
    },
    "google-slides": {
      "description": "Google Slides focused workspace subagent",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "google-workspace-official_slides_*": true,
        "google-workspace-official_auth_*": true,
        "google-workspace-official_time_*": true,
        "google-workspace-official_people_*": true,
        "google-workspace-official_chat_*": false
      }
    },
    "google-sheets": {
      "description": "Google Sheets focused workspace subagent",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "google-workspace-official_sheets_*": true,
        "google-workspace-official_auth_*": true,
        "google-workspace-official_time_*": true,
        "google-workspace-official_people_*": true,
        "google-workspace-official_chat_*": false
      }
    },
    "google-calendar": {
      "description": "Google Calendar focused workspace subagent",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "google-workspace-official_calendar_*": true,
        "google-workspace-official_auth_*": true,
        "google-workspace-official_time_*": true,
        "google-workspace-official_people_*": true,
        "google-workspace-official_chat_*": false
      }
    },
    "google-drive": {
      "description": "Google Drive focused workspace subagent",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "google-workspace-official_drive_*": true,
        "google-workspace-official_auth_*": true,
        "google-workspace-official_time_*": true,
        "google-workspace-official_people_*": true,
        "google-workspace-official_chat_*": false
      }
    },
    "google-mail": {
      "description": "Read-only Gmail focused workspace subagent",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "google-workspace-official_gmail_search": true,
        "google-workspace-official_gmail_get": true,
        "google-workspace-official_gmail_downloadAttachment": true,
        "google-workspace-official_gmail_listLabels": true,
        "google-workspace-official_gmail_modify": false,
        "google-workspace-official_gmail_batchModify": false,
        "google-workspace-official_gmail_modifyThread": false,
        "google-workspace-official_gmail_send": false,
        "google-workspace-official_gmail_createDraft": false,
        "google-workspace-official_gmail_sendDraft": false,
        "google-workspace-official_gmail_createLabel": false,
        "google-workspace-official_auth_*": true,
        "google-workspace-official_time_*": true,
        "google-workspace-official_people_*": true,
        "google-workspace-official_chat_*": false
      }
    },
    "browser": {
      "description": "Browser automation agent - use browser_* tools to control Chrome",
      "mode": "primary",
      "tools": {
        "browser_*": true
      }
    },
    "obsidian": {
      "description": "Obsidian operations agent using Obsidian CLI/headless via bash",
      "mode": "subagent",
      "prompt": "You are the Obsidian operations agent. Resolve vault before mutating operations. Prefer non-destructive actions and require explicit user intent for destructive operations.",
      "permission": {
        "skill": {
          "obsidian-*": "allow",
          "*": "allow"
        }
      },
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "browser_*": false
      }
    }
  }
}
